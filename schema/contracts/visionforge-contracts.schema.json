        "machine_assisted",
        "imported"
      ],
      "title": "ProvenanceSummary",
      "type": "object"
    },
    "Review": {
      "additionalProperties": false,
      "properties": {
        "reviewed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewed At"
        },
        "reviewer": {
          "anyOf": [
            {
              "maxLength": 256,
