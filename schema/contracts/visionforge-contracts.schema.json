          "title": "Reviewer"
        },
        "status": {
          "enum": [
            "draft",
            "queued_fast",
            "queued_detail",
            "queued_manual",
            "approved",
            "edited_approved",
            "rejected"
          ],
          "title": "ReviewStatus",
          "type": "string"
        }
      },
      "title": "Review",
      "type": "object"
    },
    "ReviewEvent": {
      "additionalProperties": false,
      "description": "一次人為審核動作。Label 記結果，ReviewEvent 記行為——含否決與盲審。\n\ncontext=blind_audit／honeypot 是防線五的量測資料：盲審比對估計漏網錯誤率，\n蜜罐量測審核者當下狀態（R1 §9.3）。",
      "properties": {
        "actor": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Actor",
          "type": "string"
        },
        "at": {
          "format": "date-time",
          "title": "At",
          "type": "string"
        },
        "claim_ref": {
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "title": "Claim Ref",
          "type": "string"
        },
        "context": {
          "default": "normal",
          "enum": [
            "normal",
            "blind_audit",
            "honeypot"
          ],
          "title": "Context",
          "type": "string"
        },
        "duration_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Duration Ms"
        },
        "event_id": {
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "title": "Event Id",
          "type": "string"
        },
        "from_status": {
          "enum": [
            "draft",
            "queued_fast",
            "queued_detail",
            "queued_manual",
            "approved",
            "edited_approved",
            "rejected"
          ],
          "title": "ReviewStatus",
          "type": "string"
        },
        "label_ref": {
          "anyOf": [
            {
              "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label Ref"
        },
        "schema_version": {
          "const": "1.0",
          "default": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "to_status": {
          "enum": [
            "draft",
            "queued_fast",
            "queued_detail",
            "queued_manual",
            "approved",
            "edited_approved",
            "rejected"
          ],
          "title": "ReviewStatus",
          "type": "string"
        }
      },
      "required": [
        "event_id",
        "at",
        "actor",
        "claim_ref",
        "from_status",
        "to_status"
      ],
      "title": "ReviewEvent",
      "type": "object"
    },
    "UnknownGeometry": {
      "additionalProperties": true,
      "description": "前向相容（F1）：未知幾何型別保留原文、標記不可解讀，不得丟棄。\n\n注意：已知型別若格式錯誤，必須報錯而非落入本類——否則壞資料會偽裝成未來資料。",
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "UnknownGeometry",
      "type": "object"
    },
    "WholeImage": {
      "additionalProperties": false,
      "description": "圖級陳述（無幾何）；absence 斷言的唯一合法幾何。",
      "properties": {
        "type": {
          "const": "whole_image",
          "default": "whole_image",
          "title": "Type",
          "type": "string"
        }
      },
      "title": "WholeImage",
      "type": "object"
    }
  },
