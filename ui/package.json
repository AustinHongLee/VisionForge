{
  "name": "visionforge-ui",
  "version": "0.1.0",
  "private": true,
  "description": "VisionForge Electron shell",
  "type": "module",
  "main": "out/main/index.js",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"*.config.ts\"",
    "test": "vitest run",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "build": "tsc --noEmit -p tsconfig.json && eslint \"src/**/*.{ts,tsx}\" \"*.config.ts\" && electron-vite build",
    "dist": "tsc --noEmit -p tsconfig.json && eslint \"src/**/*.{ts,tsx}\" \"*.config.ts\" && electron-vite build && electron-builder --win",
    "dist:dir": "tsc --noEmit -p tsconfig.json && eslint \"src/**/*.{ts,tsx}\" \"*.config.ts\" && electron-vite build && electron-builder --win --dir"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "dependency-cruiser": "^18.0.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
